# Copy to `.env` and fill in. `.env` is gitignored — never commit the real token.
# Auto-loaded everywhere: `python -m forecasting …`, `make experiment`, `make check-endpoint`,
# and `docker compose up` all read it. A var exported in your shell still overrides `.env`.

# The Hugging Face Space serving TimesFM. Leave unset to skip TimesFM (tree/baseline models only).
FORECAST_TIMESFM_ENDPOINT=https://paubernat3030-times-fm-server.hf.space/forecast

# Bearer token — only if the Space is private. Get it from whoever owns the Space (out-of-band:
# password/secret manager, not chat). Leave blank for a public Space.
FORECAST_TIMESFM_ENDPOINT_TOKEN=
