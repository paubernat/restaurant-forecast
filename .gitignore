# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/
.ruff_cache/

# Data — the Recruit CSVs are committed so the repo is self-contained (docker run works anywhere).
# hpg_reserve.csv is 120MB (> GitHub's 100MB limit), so only its .gz is committed; the loader
# (adapters/data/recruit_csv.py) reads .csv or .csv.gz. Keep the uncompressed one out of commits.
data/raw/hpg_reserve.csv

# Artifacts & experiment tracking
artifacts/
mlruns/
mlflow.db
*.parquet

# Per-run logs (logs/<cv_run_id>.log)
logs/
*.log

# TimesFM remote-forecast cache (content-addressed .npz per series; FORECAST_TIMESFM_CACHE_DIR)
.cache/
checkpoints/

# Secrets — never commit the HF Space token. Keep it in a local .env (read by docker compose).
.env
*.env
!.env.example

# Notebooks
.ipynb_checkpoints/

# OS / editor
.DS_Store
.idea/
.vscode/
